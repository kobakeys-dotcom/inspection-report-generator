RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Handle CORS preflight
RewriteRule ^(.*)$ - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# Route API requests
RewriteRule ^rfis/?$ rfis.php [L,QSA]
RewriteRule ^rfis/([0-9]+)/?$ rfis.php?id=$1 [L,QSA]
RewriteRule ^checklist-defaults/?$ checklist-defaults.php [L,QSA]
